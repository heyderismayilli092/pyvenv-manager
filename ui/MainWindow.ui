                  </object>
                </child>
              </object>
            </property>
            <property name="name">venvrm_connections</property>
          </object>
        </child>
        <child>
          <object class="GtkStackPage" id="venvrm_process">
            <property name="child">
              <object class="GtkBox">
                <property name="homogeneous">True</property>
                <property name="orientation">vertical</property>
                <child>
                  <object class="GtkSpinner">
                    <property name="spinning">True</property>
                  </object>
                </child>
                <child>
