<?xml version='1.0' encoding='UTF-8'?>
<!-- Created with Cambalache 1.0 -->
<interface>
  <!-- interface-name MainWindow.ui -->
  <requires lib="gdk" version="4.16"/>
  <requires lib="gio" version="2.0"/>
  <requires lib="gtk" version="4.12"/>
  <menu id="python_menu">
    <item>
      <attribute name="action">win.select-python3</attribute>
      <attribute name="label">Python 3</attribute>
    </item>
    <item>
      <attribute name="action">win.select-python2</attribute>
      <attribute name="label">Python 2</attribute>
    </item>
  </menu>
  <object class="GtkWindow" id="main_window">
    <property name="default-height">450</property>
    <property name="default-width">800</property>
    <property name="title">Python Environment Manager</property>
    <property name="titlebar">
      <object class="GtkHeaderBar">
        <property name="cursor">
          <object class="GdkCursor"/>
        </property>
        <property name="title-widget">
          <object class="GtkLabel">
            <property name="label">Python Environment Manager</property>
          </object>
        </property>
        <property name="use-native-controls">True</property>
      </object>
    </property>
    <accessibility>
      <state name="invalid">true</state>
    </accessibility>
    <child>
      <object class="GtkBox" id="panelbox">
        <property name="baseline-child">0</property>
        <property name="orientation">vertical</property>
        <child>
          <object class="GtkStack" id="mainwindow_stack">
            <child>
              <object class="GtkStackPage" id="page0">
                <property name="child">
                  <object class="GtkBox">
                    <property name="orientation">vertical</property>
                    <child>
                      <object class="GtkBox" id="buttons">
                        <property name="margin-bottom">8</property>
                        <property name="margin-end">0</property>
                        <property name="margin-start">7</property>
                        <property name="margin-top">8</property>
                        <child>
                          <object class="GtkButton" id="about_button">
                            <property name="icon-name">help-about-symbolic</property>
                          </object>
                        </child>
                        <child>
                          <object class="GtkButton" id="new_environment">
                            <property name="icon-name">list-add-symbolic</property>
                            <property name="margin-start">5</property>
                            <property name="width-request">0</property>
                          </object>
                        </child>
                        <child>
                          <object class="GtkButton" id="connect_pyfile">
                            <property name="label">Connect Python File</property>
                            <property name="margin-start">5</property>
                          </object>
                        </child>
                        <child>
                          <object class="GtkButton" id="connect_pyapp">
                            <property name="label">Connect Python App</property>
                            <property name="margin-start">5</property>
                          </object>
                        </child>
                        <child>
                          <object class="GtkButton" id="connection_list">
                            <property name="label">Connections List</property>
                            <property name="margin-start">5</property>
                          </object>
                        </child>
                      </object>
                    </child>
                    <child>
                      <object class="GtkLabel" id="environments_list_label">
                        <property name="label">Environments list:</property>
                        <property name="margin-bottom">5</property>
                        <property name="margin-top">10</property>
                      </object>
                    </child>
                    <child>
                      <object class="GtkSeparator">
                        <property name="margin-top">10</property>
                      </object>
                    </child>
                    <child>
                      <object class="GtkStack" id="environments_stack">
                        <child>
                          <object class="GtkStackPage" id="environments_listbox_page">
                            <property name="child">
                              <object class="GtkBox">
                                <property name="orientation">vertical</property>
                                <child>
                                  <object class="GtkScrolledWindow">
                                    <child>
                                      <object class="GtkListBox" id="environments_listbox">
                                        <property name="vexpand">True</property>
                                      </object>
                                    </child>
                                  </object>
                                </child>
                              </object>
                            </property>
                            <property name="name">environments_listbox_page</property>
                          </object>
                        </child>
                        <child>
                          <object class="GtkStackPage" id="environments_notfound">
                            <property name="child">
                              <object class="GtkBox">
                                <property name="homogeneous">True</property>
                                <property name="orientation">vertical</property>
                                <child>
                                  <object class="GtkImage">
                                    <property name="icon-name">edit-none-symbolic</property>
                                    <property name="pixel-size">100</property>
                                  </object>
                                </child>
                                <child>
                                  <object class="GtkLabel">
                                    <property name="label">No virtual environment exists yet</property>
                                  </object>
                                </child>
                              </object>
                            </property>
                            <property name="name">environments_notfound</property>
                          </object>
                        </child>
                      </object>
                    </child>
                  </object>
                </property>
                <property name="name">page0</property>
              </object>
            </child>
            <child>
              <object class="GtkStackPage" id="page1">
                <property name="child">
                  <object class="GtkBox">
                    <property name="homogeneous">True</property>
                    <property name="orientation">vertical</property>
                    <child>
                      <object class="GtkSpinner">
                        <property name="margin-bottom">10</property>
                        <property name="margin-top">10</property>
                        <property name="spinning">True</property>
                      </object>
                    </child>
                    <child>
                      <object class="GtkLabel" id="progress_status_label"/>
                    </child>
                  </object>
                </property>
                <property name="name">page1</property>
              </object>
            </child>
            <child>
              <object class="GtkStackPage" id="page2">
                <property name="child">
                  <object class="GtkBox">
                    <property name="homogeneous">True</property>
                    <child>
                      <object class="GtkBox">
                        <property name="orientation">vertical</property>
                        <child>
                          <object class="GtkImage" id="environment_about_img">
                            <property name="margin-top">30</property>
                            <property name="pixel-size">70</property>
                          </object>
                        </child>
                        <child>
                          <object class="GtkLabel" id="environment_about_name">
                            <property name="margin-top">20</property>
                          </object>
                        </child>
                        <child>
                          <object class="GtkButton" id="back_mainwindow">
                            <property name="label">Back main window</property>
                            <property name="margin-top">20</property>
                          </object>
                        </child>
                        <child>
                          <object class="GtkButton" id="install_new_package">
                            <property name="label">Install new package</property>
                            <property name="margin-top">5</property>
                          </object>
                        </child>
                        <child>
                          <object class="GtkSeparator">
                            <property name="margin-bottom">3</property>
                            <property name="margin-top">3</property>
                          </object>
                        </child>
                        <child>
                          <object class="GtkStack" id="connected_pages">
                            <child>
                              <object class="GtkStackPage" id="connected_fileslist">
                                <property name="child">
                                  <object class="GtkBox">
                                    <property name="margin-top">3</property>
                                    <property name="orientation">vertical</property>
                                    <child>
                                      <object class="GtkLabel">
                                        <property name="label">Connected Files:</property>
                                        <property name="lines">-2</property>
                                      </object>
                                    </child>
                                    <child>
                                      <object class="GtkScrolledWindow">
                                        <child>
                                          <object class="GtkListBox" id="list_connfiles">
                                            <property name="vexpand">True</property>
                                          </object>
                                        </child>
                                      </object>
                                    </child>
                                  </object>
                                </property>
                                <property name="name">connected_fileslist</property>
                              </object>
                            </child>
                            <child>
                              <object class="GtkStackPage" id="connected_appslist">
                                <property name="child">
                                  <object class="GtkBox">
                                    <property name="margin-top">3</property>
                                    <property name="orientation">vertical</property>
                                    <child>
                                      <object class="GtkLabel">
                                        <property name="label">Connected Apps:</property>
                                      </object>
                                    </child>
                                    <child>
                                      <object class="GtkScrolledWindow">
                                        <child>
                                          <object class="GtkListBox" id="list_connapps">
                                            <property name="vexpand">True</property>
                                          </object>
                                        </child>
                                      </object>
                                    </child>
                                  </object>
                                </property>
                                <property name="name">connected_appslist</property>
                              </object>
                            </child>
                            <child>
                              <object class="GtkStackPage" id="connected_notfound">
                                <property name="child">
                                  <object class="GtkBox">
                                    <property name="homogeneous">True</property>
                                    <property name="orientation">vertical</property>
                                    <child>
                                      <object class="GtkImage">
                                        <property name="icon-name">dialog-error-symbolic</property>
                                        <property name="pixel-size">32</property>
                                      </object>
                                    </child>
                                    <child>
                                      <object class="GtkLabel">
                                        <property name="label">No files were found linked to this environment!</property>
                                      </object>
                                    </child>
                                  </object>
                                </property>
                                <property name="name">connected_notfound</property>
                              </object>
                            </child>
                          </object>
                        </child>
                        <child>
                          <object class="GtkButton" id="change_connpage">
                            <property name="label">Change</property>
                            <property name="margin-bottom">2</property>
                            <property name="margin-top">3</property>
                          </object>
                        </child>
                      </object>
                    </child>
                    <child>
                      <object class="GtkBox">
                        <property name="orientation">vertical</property>
                        <child>
                          <object class="GtkBox" id="venvinfo_cfg_exists">
                            <property name="margin-top">4</property>
                            <property name="orientation">vertical</property>
                            <child>
                              <object class="GtkLabel" id="venvinfo_cfg">
                                <property name="margin-bottom">2</property>
                              </object>
                            </child>
                            <child>
                              <object class="GtkLabel" id="venvinfo_implementation">
                                <property name="margin-bottom">2</property>
                              </object>
                            </child>
                            <child>
                              <object class="GtkLabel" id="venvinfo_versioninfo">
                                <property name="margin-bottom">2</property>
                              </object>
                            </child>
                            <child>
                              <object class="GtkLabel" id="venvinfo_virtualenv_version">
                                <property name="margin-bottom">2</property>
                              </object>
                            </child>
                            <child>
                              <object class="GtkLabel" id="venvinfo_baseprefix">
                                <property name="margin-bottom">2</property>
                              </object>
                            </child>
                            <child>
                              <object class="GtkLabel" id="venvinfo_baseexecprefix">
                                <property name="margin-bottom">2</property>
                              </object>
                            </child>
                          </object>
                        </child>
                        <child>
                          <object class="GtkSeparator">
                            <property name="margin-bottom">10</property>
                            <property name="margin-top">10</property>
                          </object>
                        </child>
                        <child>
                          <object class="GtkLabel" id="installed_packages_total">
                            <property name="margin-bottom">3</property>
                          </object>
                        </child>
                        <child>
                          <object class="GtkScrolledWindow">
                            <child>
                              <object class="GtkViewport">
                                <property name="vexpand">True</property>
                                <child>
                                  <object class="GtkListBox" id="installed_packages_list"/>
                                </child>
                              </object>
                            </child>
                          </object>
                        </child>
                      </object>
                    </child>
                  </object>
                </property>
                <property name="name">page2</property>
              </object>
            </child>
            <child>
              <object class="GtkStackPage" id="page3">
                <property name="child">
                  <object class="GtkBox">
                    <property name="homogeneous">True</property>
                    <child>
                      <object class="GtkBox">
                        <property name="margin-end">5</property>
                        <property name="margin-start">-1</property>
                        <property name="orientation">vertical</property>
                        <child>
                          <object class="GtkImage">
                            <property name="icon-name">application-x-executable</property>
                            <property name="margin-top">30</property>
                            <property name="pixel-size">70</property>
                          </object>
                        </child>
                        <child>
                          <object class="GtkBox">
                            <property name="homogeneous">True</property>
                            <property name="orientation">vertical</property>
                            <child>
                              <object class="GtkLabel" id="packinfo_packname"/>
                            </child>
                            <child>
                              <object class="GtkLabel" id="packinfo_venvname">
