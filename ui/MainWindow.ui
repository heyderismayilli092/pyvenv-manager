                                <property name="margin-top">10</property>
                              </object>
                            </child>
                          </object>
                        </child>
                        <child>
                          <object class="GtkButton" id="back_mainwindow_2">
                            <property name="label">Back main window</property>
                            <property name="margin-top">20</property>
                          </object>
                        </child>
                        <child>
                          <object class="GtkButton" id="remove_package">
                            <property name="label">Remove package</property>
                            <property name="margin-top">5</property>
                          </object>
                        </child>
                      </object>
                    </child>
                    <child>
                      <object class="GtkBox">
                        <property name="orientation">vertical</property>
                        <child>
                          <object class="GtkScrolledWindow" id="packinfo_area">
                            <property name="margin-top">5</property>
                            <child>
                              <object class="GtkViewport">
                                <child>
                                  <object class="GtkBox">
                                    <property name="margin-top">10</property>
                                    <property name="orientation">vertical</property>
                                    <child>
                                      <object class="GtkBox">
                                        <property name="margin-bottom">5</property>
                                        <child>
                                          <object class="GtkLabel">
                                            <property name="label">Version:</property>
                                            <property name="xalign">0.0</property>
                                          </object>
                                        </child>
                                        <child>
                                          <object class="GtkLabel" id="packinfo_version">
                                            <property name="margin-start">5</property>
                                          </object>
                                        </child>
                                      </object>
                                    </child>
                                    <child>
                                      <object class="GtkBox">
                                        <property name="hexpand">True</property>
                                        <property name="vexpand">True</property>
                                        <child>
                                          <object class="GtkLabel">
                                            <property name="label">Summary:</property>
                                          </object>
                                        </child>
                                        <child>
                                          <object class="GtkLabel" id="packinfo_summary">
                                            <property name="margin-start">5</property>
