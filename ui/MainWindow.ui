                    <property name="label">Environment is being deleted from the computer...</property>
                  </object>
                </child>
              </object>
            </property>
            <property name="name">venvrm_process</property>
          </object>
        </child>
        <child>
          <object class="GtkStackPage" id="venvrm_success">
            <property name="child">
              <object class="GtkBox">
                <property name="homogeneous">True</property>
                <property name="orientation">vertical</property>
                <child>
